extends layout

block content
  .pokedex-container
    //- Encabezado con botón volver
    .pokedex-header
      .header-top
        a.btn-back(href='javascript:history.back()') ← Volver
        h1.pokedex-title Pokédex del Usuario
      p.pokedex-subtitle Gestiona los Pokémon capturados

    //- Filtros y acciones
    .pokedex-controls
      .controls-left
        .search-group
          input#pokemonSearch.search-input(
            type='text'
            placeholder='Buscar Pokémon...'
          )

        .sort-group
          label(for='sortBy') Ordenar por:
          select#sortBy.filter-select
            option(value='name') Nombre (A-Z)
            option(value='id') ID (menor a mayor)

      .controls-right
        button#addPokemonBtn.btn-add + Añadir Pokémon

    //- Tabla de Pokémon
    .table-wrapper
      table.pokedex-table
        thead
          tr
            th ID
            th Nombre
            th Slot
            th Capturado
            th Acciones

        tbody#pokemonTableBody
          tr
            td(colspan='5').loading Cargando Pokémon...

    //- Contador
    .pokedex-footer
      span#pokemonCountTotal Total: 0 Pokémon capturados

    //- Modal añadir Pokémon
    #addPokemonModal.modal(style='display: none;')
      .modal-content
        .modal-header
          h2 Añadir Pokémon Capturado
          button.modal-close(type='button' onclick='closeAddModal()') ✕
        
        .modal-body
          form#addPokemonForm
            .form-group
              label(for='pokemonId') ID Pokémon (Pokedex)
              input#pokemonId(
                type='number'
                placeholder='Ej: 25 (Pikachu)'
                required
                min='1'
              )
            
            .form-group
              label(for='pokemonName') Nombre Pokémon
              input#pokemonName(
                type='text'
                placeholder='Ej: Pikachu'
                required
              )

            .form-group
              label(for='slotId') Slot de Partida (opcional)
              select#slotId.filter-select
                option(value='') Sin asignar
                option(value='1') Slot 1
                option(value='2') Slot 2
                option(value='3') Slot 3

            .form-group
              label(for='isGlobal')
                input#isGlobal(type='checkbox')
                span  Añadir a Pokédex global (visible en estadísticas)
        
        .modal-footer
          button.btn-secondary(type='button' onclick='closeAddModal()') Cancelar
          button.btn-primary(type='button' onclick='addPokemon()') Añadir

block scripts
  script(src='/js/pokedex.js')