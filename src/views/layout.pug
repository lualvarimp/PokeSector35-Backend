doctype html
html(lang='es')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(name='description' content='Panel de administración PokéSector 35')
    title= title || 'PokéSector Admin - Dashboard'
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='/css/layout.css')
    link(rel='stylesheet' href='/css/dashboard.css')
  
  body
    //- Navbar con menú dinámico
    nav.navbar
      div
        .logo-placeholder
          a(href='/') POKÉSECTOR ADMIN
        
        button#menuToggle
          span
          span
          span
        
        ul#navMenu
          //- Menú Admin
          li#adminMenu(style='display: none;')
            a(href='/admin/dashboard') Dashboard
          li#adminMenu(style='display: none;')
            a(href='/admin/users') Usuarios
          li#adminMenu(style='display: none;')
            a(href='/admin/ranking') Ranking
          li#adminMenu(style='display: none;')
            a(href='/admin/logout') Logout
          
          //- Menú User
          li#userMenu(style='display: none;')
            a(href='/user/dashboard') Dashboard
          li#userMenu(style='display: none;')
            a(href='/user/profile') Mi Perfil
          li#userMenu(style='display: none;')
            a(href='/user/ranking') Ranking
          li#userMenu(style='display: none;')
            a(href='/user/logout') Logout
        
        .theme-toggle
          input#themeSwitch(type='checkbox')
          label(for='themeSwitch')

    //- Main content
    main.main-content
      block content

    //- Scripts
    script(src='/js/layout.js')
    block scripts